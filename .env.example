# open-greg environment configuration
# Copy this file to .env and fill in values. Never commit .env.

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Options: "ollama" (local, no key needed) or "anthropic"
# Defaults to "ollama" unless ANTHROPIC_API_KEY is set
LLM_PROVIDER=ollama

# Local Ollama (start with: ollama serve)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Anthropic Claude (leave blank if using Ollama)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── Ports ─────────────────────────────────────────────────────────────────────
PORT=3030
DASHBOARD_PORT=3000
CONTROL_PLANE_PORT=3001

# ── Database (only needed for Docker / control-plane) ─────────────────────────
DATABASE_URL=postgresql://greg:greg@localhost:5432/greg
REDIS_URL=redis://localhost:6379

# ── Messaging (all optional) ──────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# ── Security ──────────────────────────────────────────────────────────────────
# Required on headless Linux without keyring (encrypts stored credentials)
# Generate with: openssl rand -base64 32
GREG_SECRET_PASSPHRASE=

# ── Next.js public vars ───────────────────────────────────────────────────────
NEXT_PUBLIC_CONTROL_PLANE_URL=http://localhost:3001
