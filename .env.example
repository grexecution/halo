# claw-alt root environment example
# Copy to .env and fill in values. Never commit .env.

# ─── Secrets ──────────────────────────────────────────────────────────────────
# Required on headless Linux (no GNOME keyring). Leave unset on macOS/desktop.
# CLAW_SECRET_PASSPHRASE=<generate with: openssl rand -hex 32>

# ─── LLM ──────────────────────────────────────────────────────────────────────
# LLM_PROVIDER=anthropic   # anthropic | openai | ollama
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# ─── Database ─────────────────────────────────────────────────────────────────
# Set by docker/compose.yml; override here only if using external Postgres
# DATABASE_URL=postgresql://claw:claw@localhost:5432/claw

# ─── Redis ────────────────────────────────────────────────────────────────────
# REDIS_URL=redis://localhost:6379

# ─── Ports ────────────────────────────────────────────────────────────────────
# DASHBOARD_PORT=3000
# CONTROL_PLANE_PORT=3001

# ─── Build cost cap ───────────────────────────────────────────────────────────
# BUILD_COST_SOFT_CAP_USD=10
# BUILD_COST_HARD_CAP_USD=50
